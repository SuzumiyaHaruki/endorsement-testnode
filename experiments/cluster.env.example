#!/usr/bin/env bash

# Load this file before running the experiment scripts:
#   cp cluster.env.example cluster.env
#   vim cluster.env
#   source ./cluster.env

export L2_RPC_URL="http://127.0.0.1:8547"
export FAIL_TO_ADDRESS="0x1111111111111111111111111111111111111111"

# Endorser endpoints written into the generated sequencer override config.
export ENDORSER_A_URL="http://10.0.0.12:9001"
export ENDORSER_B_URL="http://10.0.0.13:9002"
export ENDORSER_C_URL="http://10.0.0.14:9003"

export ENDORSER_A_PUBKEY="replace-with-endorser-a-pubkey"
export ENDORSER_B_PUBKEY="replace-with-endorser-b-pubkey"
export ENDORSER_C_PUBKEY="replace-with-endorser-c-pubkey"

# Sequencer config and restart control.
# Leave SEQUENCER_SSH_TARGET empty if you run experiments on the sequencer host.
export SEQUENCER_SSH_TARGET=""
export SEQUENCER_CONFIG_PATH="/etc/nitro/sequencer_config.json"
export SEQUENCER_SERVICE="nitro-sequencer"
export SEQUENCER_LOG_CMD_TEMPLATE="journalctl -u nitro-sequencer --since '@__SINCE__' --no-pager"

# Optional extra SSH flags shared by scp/ssh.
export SSH_OPTS=""

# Remote nodes used by fault injection and log collection.
export ENDORSER_A_SSH_TARGET="nitro@10.0.0.12"
export ENDORSER_B_SSH_TARGET="nitro@10.0.0.13"
export ENDORSER_C_SSH_TARGET="nitro@10.0.0.14"

export ENDORSER_A_SERVICE="nitro-endorser-a"
export ENDORSER_B_SERVICE="nitro-endorser-b"
export ENDORSER_C_SERVICE="nitro-endorser-c"

export ENDORSER_A_LOG_CMD_TEMPLATE="journalctl -u nitro-endorser-a --since '@__SINCE__' --no-pager"
export ENDORSER_B_LOG_CMD_TEMPLATE="journalctl -u nitro-endorser-b --since '@__SINCE__' --no-pager"
export ENDORSER_C_LOG_CMD_TEMPLATE="journalctl -u nitro-endorser-c --since '@__SINCE__' --no-pager"

export ENDORSER_A_NET_IFACE="eth0"
export ENDORSER_B_NET_IFACE="eth0"
export ENDORSER_C_NET_IFACE="eth0"
